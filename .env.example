# WHEN DEVELOPING LOCALLY, WE NEED TO ACCESS THE HOST NETWORK FROM K8S (FOR POSTGRES/KAFKA/ELASTIC/ETC)
LOCAL_HOST_IP=$(ifconfig en0 | grep inet | grep -v inet6 | awk '{print $2}')

RUST_VERSION=1.89.0

PG_HOST=$LOCAL_HOST_IP
PG_PORT=
PG_USER=
PG_PASSWORD=
PG_DATABASE=
PG_POOL_SIZE=80

# Task reset/cleanup interval: default 5s; an externally injected value takes precedence.
: "${MONITOR_POLLING_INTERVAL_IN_SECS:=5}"
# Metrics refresh interval: default 120s; an externally injected value takes precedence.
: "${MONITOR_METRICS_REFRESH_INTERVAL_IN_SECS:=120}"
MONITOR_TASK_RETENTION_PERIOD_IN_SECS=864000

# Optional. OTLP gRPC endpoint for OpenTelemetry metrics (not the Grafana UI).
# Grafana UI is usually http://localhost:3000; OTLP is typically port 4317 on a collector/alloy/tempo service.
# Default applies only when this variable is not already set (e.g. by Docker/K8s or shell export).
# Comment out the next line in .env to disable OTLP export locally.
: "${OTEL_EXPORTER_OTLP_ENDPOINT:=http://localhost:4317}"

RUST_LOG=ERROR

# POSTGRES ENV FOR CREATE DB
PG_DATABASE_TEMPLATE=
PG_DATABASE_ADMIN=
SCYLLA_CREATE_DB=

# FOR DROPPING THE DB
#SCYLLA_CLEANUP_MODE=